{
  "systemSetup": [
    {
      "name": "Install pnpm",
      "command": "npm i -g pnpm"
    }
  ],
  "templateName": "custom",
  "projectDependencies": [
    {
      "name": "Install Dependencies",
      "command": "pnpm install"
    }
  ],
  "codeChecks": [
    {
      "name": "Typecheck",
      "command": "pnpm run typecheck"
    }
  ],
  "buildSteps": [
    {
      "name": "Build Project",
      "command": "pnpm run build"
    }
  ],
  "runStep": [
    {
      "name": "Run Dev Server",
      "command": "pnpm -C deploy run dev --port 3000",
      "port": "3000"
    }
  ],
  "deploySteps": [],
  "cleanupFiles": [
    "deploy/dist"
  ],
  "packageManager": "pnpm",
  "envPaths": [
    {
      "name": "deploy",
      "path": "deploy/.env"
    }
  ]
}
